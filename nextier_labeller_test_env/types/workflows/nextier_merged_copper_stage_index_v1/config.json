{
  "key": "nextier_merged_copper_stage_index_v1",
  "displayName": "Nextier Merged Copper Stage Index v1",
  "description": "Builds compact Copper stage windows (one row per well + copper stage) from merged_copper_labels_v1.copper_continuous and writes them to merged_copper_stage_index_v1 — the canonical stage source for the Copper Stage Detection dashboard, scoring, and anomaly workflows.",
  "runtime": "prefect",
  "flow": {
    "entrypoint": "scripts/workflows/nextier_merged_copper_stage_index_v1/main.py:nextier_merged_copper_stage_index_v1_flow",
    "include": [
      "scripts/workflows/nextier_merged_copper_stage_index_v1/**/*.py"
    ],
    "tags": [
      "nextier",
      "copper",
      "copper-pipeline"
    ]
  },
  "deployment": {
    "workPool": "default",
    "timezone": "UTC",
    "cron": "*/15 * * * *",
    "concurrencyLimit": 1,
    "parameters": {
      "mode": "incremental",
      "max_wells": 25,
      "algorithm_version": "copper-v1",
      "stage_layer": "continuous",
      "dry_run": false
    }
  },
  "paramsSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "enum": ["live", "incremental", "historical", "rebuild"],
        "default": "incremental"
      },
      "max_wells": {
        "type": "integer",
        "default": 25,
        "minimum": 1,
        "maximum": 1000
      },
      "well_name": {
        "type": "string"
      },
      "algorithm_version": {
        "type": "string",
        "default": "copper-v1"
      },
      "stage_layer": {
        "type": "string",
        "enum": ["continuous", "provisional"],
        "default": "continuous"
      },
      "dry_run": {
        "type": "boolean",
        "default": false
      }
    },
    "required": []
  },
  "initialState": {}
}
