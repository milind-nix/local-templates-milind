{
  "key": "nextier_merged_live_processing",
  "displayName": "Nextier Merged Live Processing",
  "description": "Incrementally seeds live telemetry into merged raw data and derives merged TD stage windows plus Bronze/Platinum/Gold labels.",
  "runtime": "prefect",
  "flow": {
    "entrypoint": "scripts/workflows/nextier_merged_live_processing/main.py:nextier_merged_live_processing_flow",
    "include": [
      "scripts/workflows/nextier_merged_live_processing/**/*.py",
      "scripts/workflows/nextier_live_stage_processing/**/*.py",
      "scripts/workflows/nextier_merged_well_recompute/**/*.py"
    ],
    "tags": ["nextier", "merged-labeller", "live-processing"]
  },
  "deployment": {
    "workPool": "default",
    "timezone": "UTC",
    "cron": "*/3 * * * *",
    "concurrencyLimit": 1,
    "parameters": {
      "batch_limit": 200000,
      "td_gap_seconds": 3600
    }
  },
  "paramsSchema": {
    "type": "object",
    "properties": {
      "batch_limit": {
        "type": "integer",
        "default": 200000,
        "minimum": 1,
        "maximum": 1000000
      },
      "td_gap_seconds": {
        "type": "integer",
        "default": 3600,
        "minimum": 1
      }
    },
    "required": []
  },
  "initialState": {
    "__checkpoint__merged_live_stage_created_ts": null,
    "merged_td_stage_state_by_well": {}
  }
}
