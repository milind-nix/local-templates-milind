{
  "key": "nextier_merged_copper_stage_labeling_v1",
  "displayName": "Nextier Merged Copper Stage Labeling v1",
  "description": "Runs the canonical nextier-dash Copper layer APIs (provisional / confirmed / contextual, closed-only expansion) over merged_bronze_labels_v2 and writes row-level copper_provisional, copper_confirmed, and copper_continuous into merged_copper_labels_v1.",
  "runtime": "prefect",
  "flow": {
    "entrypoint": "scripts/workflows/nextier_merged_copper_stage_labeling_v1/main.py:nextier_merged_copper_stage_labeling_v1_flow",
    "include": [
      "scripts/workflows/nextier_merged_copper_stage_labeling_v1/**/*.py"
    ],
    "tags": [
      "nextier",
      "copper",
      "copper-pipeline"
    ]
  },
  "deployment": {
    "workPool": "default",
    "timezone": "UTC",
    "cron": "*/15 * * * *",
    "concurrencyLimit": 1,
    "parameters": {
      "mode": "incremental",
      "max_wells": 25,
      "algorithm_version": "copper-v1",
      "dry_run": false
    }
  },
  "paramsSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "enum": ["live", "incremental", "historical", "rebuild"],
        "default": "incremental"
      },
      "max_wells": {
        "type": "integer",
        "default": 25,
        "minimum": 1,
        "maximum": 1000
      },
      "well_name": {
        "type": "string"
      },
      "algorithm_version": {
        "type": "string",
        "default": "copper-v1"
      },
      "dry_run": {
        "type": "boolean",
        "default": false
      }
    },
    "required": []
  },
  "initialState": {}
}
