{
  "key": "nextier_merged_bronze_labeling_v2",
  "displayName": "Nextier Merged Bronze Labeling v2",
  "description": "Runs the canonical nextier-dash Bronze substage FSM over merged fleet-stream telemetry and writes row-level bronze_continuous. Modes: live (active wells, small overlap), incremental (rolling lookback for late data), historical (wide backfill for selected wells).",
  "runtime": "prefect",
  "flow": {
    "entrypoint": "scripts/workflows/nextier_merged_bronze_labeling_v2/main.py:nextier_merged_bronze_labeling_v2_flow",
    "include": [
      "scripts/workflows/nextier_merged_bronze_labeling_v2/**/*.py"
    ],
    "tags": [
      "nextier",
      "bronze",
      "copper-pipeline"
    ]
  },
  "deployment": {
    "workPool": "default",
    "timezone": "UTC",
    "cron": "*/15 * * * *",
    "concurrencyLimit": 1,
    "parameters": {
      "mode": "incremental",
      "max_wells": 25,
      "algorithm_version": "bronze-v2",
      "lookback_hours": 72,
      "td_gap_seconds": 3600,
      "dry_run": false
    }
  },
  "paramsSchema": {
    "type": "object",
    "properties": {
      "mode": {
        "type": "string",
        "enum": ["live", "incremental", "historical", "rebuild"],
        "default": "incremental"
      },
      "max_wells": {
        "type": "integer",
        "default": 25,
        "minimum": 1,
        "maximum": 1000
      },
      "well_name": {
        "type": "string"
      },
      "algorithm_version": {
        "type": "string",
        "default": "bronze-v2"
      },
      "lookback_hours": {
        "type": "integer",
        "default": 72,
        "minimum": 1
      },
      "td_gap_seconds": {
        "type": "integer",
        "default": 3600,
        "minimum": 1
      },
      "dry_run": {
        "type": "boolean",
        "default": false
      }
    },
    "required": []
  },
  "initialState": {}
}
