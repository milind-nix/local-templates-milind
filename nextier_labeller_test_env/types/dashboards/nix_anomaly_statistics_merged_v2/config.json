              "top": 20,
              "left": 150,
              "right": 30,
              "bottom": 35,
              "containLabel": true
            },
            "xAxis": {
              "type": "value",
              "name": "Segments"
            },
            "yAxis": {
              "type": "category"
            },
            "dataset": {
              "source": "data:dataset",
              "dimensions": [
                "types.anomaly_type",
                "types.anomaly_lines",
                "types.color"
              ]
            },
            "series": [
              {
                "type": "bar",
                "encode": {
                  "x": "types.anomaly_lines",
                  "y": "types.anomaly_type",
                  "tooltip": ["types.anomaly_type", "types.anomaly_lines"]
                },
                "itemStyle": {
                  "color": "functionString:return params.value[2]"
                },
                "barMaxWidth": 34,
                "label": {
                  "show": true,
                  "position": "right"
                }
              }
            ]
          }
        }
