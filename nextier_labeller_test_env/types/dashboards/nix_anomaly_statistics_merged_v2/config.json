{
  "key": "nix_anomaly_statistics_merged_v2",
  "displayName": "Anomaly Statistics",
  "description": "Active-run anomaly segment statistics and drilldown.",
  "order": 31,
  "config": {
    "updateInterval": "5m",
    "specVersion": "v2"
  },
  "paramsSchema": {
    "type": "object",
    "properties": {},
    "required": []
  },
  "filters": [],
  "charts": [],
  "spec": {
    "specVersion": "v2",
    "theme": {
      "preset": "corporate"
    },
    "state": {
      "params": {
        "fleet_name": {
          "type": "string",
          "default": null
        },
        "pad_name": {
          "type": "string",
          "default": null
        },
        "well_name": {
          "type": "string",
          "default": "__ALL__"
        },
        "stage_num": {
          "type": "string",
          "default": "-1"
        }
      }
    },
    "navigation": {
      "initialView": "main"
    },
    "widgets": [
      {
        "id": "scope",
        "title": "Scope",
        "chrome": {
          "showActions": false,
          "hideTitle": true,
          "padding": 10,
          "disableCard": false
        },
        "renderConfig": {
          "library": "Custom",
          "options": {
            "type": "form",
            "config": {
              "schema": {
                "type": "object",
                "required": ["fleet_name", "pad_name"],
                "properties": {
                  "fleet_name": {
                    "type": "string",
                    "metadata": {
                      "ui": {
                        "label": "Fleet",
                        "component": "select",
                        "placeholder": "Select fleet",
                        "optionsMetric": {
                          "metricKey": "merged_fleet_options_v1",
                          "valuePath": "value",
                          "labelPath": "label"
                        },
                        "onChangeEventId": "fleet_changed"
                      }
                    }
                  },
                  "pad_name": {
                    "type": "string",
                    "metadata": {
                      "ui": {
                        "label": "Pad",
                        "component": "select",
                        "placeholder": "Select pad",
                        "optionsMetric": {
                          "metricKey": "merged_pad_options_v1",
                          "params": {
                            "fleet_name": "{{form.fleet_name}}"
                          },
                          "valuePath": "value",
                          "labelPath": "label"
                        },
                        "onChangeEventId": "pad_changed"
                      }
                    }
                  },
                  "well_name": {
                    "type": "string",
                    "metadata": {
                      "ui": {
                        "label": "Well",
                        "component": "select",
                        "placeholder": "All wells",
                        "clearable": true,
                        "optionsMetric": {
                          "metricKey": "merged_well_options_v1",
                          "params": {
                            "fleet_name": "{{form.fleet_name}}",
                            "pad_name": "{{form.pad_name}}"
                          },
                          "valuePath": "value",
                          "labelPath": "label"
                        }
                      }
                    }
                  }
                }
              },
              "layout": {
                "cols": 12,
                "gap": 10,
                "rows": [
                  {
                    "items": [
                      {
                        "type": "field",
                        "key": "fleet_name",
                        "colSpan": 3
                      },
                      {
                        "type": "field",
                        "key": "pad_name",
                        "colSpan": 3
                      },
                      {
                        "type": "field",
                        "key": "well_name",
                        "colSpan": 5
                      },
                      {
                        "type": "button",
                        "key": "apply",
                        "colSpan": 1,
                        "align": "end"
                      }
                    ]
                  }
                ]
              },
              "actions": [
                {
                  "id": "apply",
                  "label": "Apply",
                  "kind": "submit",
                  "eventId": "apply",
                  "ui": {
                    "color": "primary",
                    "variant": "solid",
                    "size": "sm",
                    "radius": "sm",
                    "fullWidth": true
                  }
                }
              ]
            }
          }
        },
        "events": {
          "fleet_changed": [
            {
              "type": "set_form_values",
              "updates": {
                "fleet_name": "{{form.fleet_name}}",
                "pad_name": null,
                "well_name": null
              }
            }
          ],
          "pad_changed": [
            {
              "type": "set_form_values",
              "updates": {
                "fleet_name": "{{form.fleet_name}}",
                "pad_name": "{{form.pad_name}}",
                "well_name": null
              }
            }
          ],
          "apply": [
            {
              "type": "set_state",
              "updates": {
                "fleet_name": "{{form.fleet_name}}",
                "pad_name": "{{form.pad_name}}",
                "well_name": "{{form.well_name}}",
                "stage_num": "-1"
              }
            }
          ]
        }
      },
      {
