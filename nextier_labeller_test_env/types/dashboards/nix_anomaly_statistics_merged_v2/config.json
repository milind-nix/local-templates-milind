      {
        "id": "stage_filter",
        "title": "Stage Anomaly Segments",
        "chrome": {
          "showActions": false,
          "hideTitle": false,
          "padding": 8,
          "disableCard": false
        },
        "renderConfig": {
          "library": "Custom",
          "options": {
            "type": "select",
            "config": {
              "placeholder": "Select stage",
              "selectionMode": "single",
              "optionsMetric": {
                "metricKey": "merged_presence_stage_options_v1",
                "params": {
                  "well_name": "{{state.well_name}}"
                },
                "required": ["well_name"],
                "valuePath": "value",
                "labelPath": "label"
              },
              "value": "{{state.stage_num}}"
            },
            "ui": {
              "size": "sm",
              "variant": "bordered",
              "radius": "sm",
              "fullWidth": false,
              "width": 320
            }
          }
        },
        "events": {
          "onChange": [
            {
              "type": "set_state",
              "updates": {
                "stage_num": "{{event.lastSelectedValue}}"
              }
            }
          ]
        }
      },
      {
        "id": "stage_segments",
        "title": "Stage Overview with Anomaly Segments",
        "description": "Raw stage telemetry with active anomaly windows.",
        "isDataLarge": true,
        "chrome": {
          "showActions": false,
          "padding": 8,
          "disableCard": false
        },
        "dataConfig": {
          "chart_data": {
