{
  "key": "anomaly_threshold_tuning_merged_v1",
  "displayName": "Anomaly Threshold Tuning",
  "description": "Tune DESIGN/slurry delta thresholds using compact precomputed counts.",
  "order": 32,
  "config": {
    "updateInterval": "5m",
    "specVersion": "v2"
  },
  "paramsSchema": {
    "type": "object",
    "properties": {},
    "required": []
  },
  "filters": [],
  "charts": [],
  "spec": {
    "specVersion": "v2",
    "theme": {
      "preset": "corporate"
    },
    "state": {
      "params": {
        "fleet_name": {
          "type": "string",
          "default": null
        },
        "pad_name": {
          "type": "string",
          "default": null
        },
        "well_name": {
          "type": "string",
          "default": "__ALL__"
        },
        "pressure_threshold": {
          "type": "number",
          "default": 200
        },
        "rate_threshold": {
          "type": "number",
          "default": 5
        },
        "rolling_points": {
          "type": "integer",
          "default": 1
        },
        "inspect_well": {
          "type": "string",
          "default": null
        },
        "inspect_stage": {
          "type": "string",
          "default": "-1"
        }
      }
    },
    "navigation": {
      "initialView": "main"
    },
    "widgets": [
      {
        "id": "controls",
        "title": "Tuning Controls",
        "chrome": {
          "showActions": false,
          "hideTitle": true,
          "padding": 10,
          "disableCard": false
        },
        "renderConfig": {
          "library": "Custom",
          "options": {
            "type": "form",
            "config": {
              "schema": {
                "type": "object",
                "required": [
                  "fleet_name",
                  "pad_name",
                  "pressure_threshold",
                  "rate_threshold",
                  "rolling_points"
                ],
                "properties": {
                  "fleet_name": {
                    "type": "string",
                    "metadata": {
                      "ui": {
                        "label": "Fleet",
                        "component": "select",
                        "placeholder": "Select fleet",
                        "optionsMetric": {
                          "metricKey": "merged_fleet_options_v1",
                          "valuePath": "value",
                          "labelPath": "label"
                        },
                        "onChangeEventId": "fleet_changed"
                      }
                    }
                  },
                  "pad_name": {
                    "type": "string",
                    "metadata": {
                      "ui": {
                        "label": "Pad",
                        "component": "select",
                        "placeholder": "Select pad",
                        "optionsMetric": {
                          "metricKey": "merged_pad_options_v1",
                          "params": {
                            "fleet_name": "{{form.fleet_name}}"
                          },
                          "valuePath": "value",
                          "labelPath": "label"
                        },
                        "onChangeEventId": "pad_changed"
                      }
                    }
                  },
                  "well_name": {
                    "type": "string",
                    "metadata": {
                      "ui": {
                        "label": "Well",
                        "component": "select",
                        "placeholder": "All wells",
                        "clearable": false,
                        "optionsMetric": {
                          "metricKey": "merged_anomaly_tuning_well_options_v1",
                          "params": {
                            "fleet_name": "{{form.fleet_name}}",
                            "pad_name": "{{form.pad_name}}"
                          },
                          "valuePath": "value",
                          "labelPath": "label"
                        }
                      }
                    }
                  },
                  "pressure_threshold": {
                    "type": "number",
                    "minimum": 50,
                    "maximum": 500,
                    "multipleOf": 10,
                    "metadata": {
                      "ui": {
                        "label": "Pressure Threshold (psi/step)",
                        "component": "slider",
                        "showTooltip": true,
                        "marks": [
                          {
                            "value": 50,
                            "label": "50"
                          },
                          {
                            "value": 200,
                            "label": "200"
                          },
                          {
                            "value": 300,
                            "label": "300"
                          },
                          {
                            "value": 500,
                            "label": "500"
                          }
                        ]
                      }
                    }
                  },
                  "rate_threshold": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 20,
                    "multipleOf": 1,
                    "metadata": {
                      "ui": {
                        "label": "Rate-Drop Threshold (bpm/step)",
                        "component": "slider",
                        "showTooltip": true,
                        "marks": [
                          {
                            "value": 1,
                            "label": "1"
                          },
                          {
                            "value": 5,
                            "label": "5"
                          },
                          {
                            "value": 10,
                            "label": "10"
                          },
                          {
                            "value": 20,
                            "label": "20"
                          }
                        ]
                      }
                    }
                  },
                  "rolling_points": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 10,
                    "metadata": {
                      "ui": {
                        "label": "Rolling Window (points)",
                        "component": "slider",
                        "showTooltip": true,
                        "marks": [
                          {
                            "value": 1,
                            "label": "1"
                          },
                          {
                            "value": 3,
                            "label": "3"
                          },
                          {
                            "value": 5,
                            "label": "5"
                          },
                          {
                            "value": 10,
                            "label": "10"
                          }
                        ],
                        "showSteps": true
                      }
                    }
                  }
                }
              },
              "initialValues": {
                "pressure_threshold": 200,
                "rate_threshold": 5,
                "rolling_points": 1,
                "well_name": "__ALL__"
              },
              "layout": {
                "cols": 12,
                "gap": 10,
                "rows": [
                  {
                    "items": [
                      {
                        "type": "field",
                        "key": "fleet_name",
                        "colSpan": 3
                      },
                      {
                        "type": "field",
                        "key": "pad_name",
                        "colSpan": 3
                      },
                      {
                        "type": "field",
                        "key": "well_name",
                        "colSpan": 6
                      }
                    ]
                  },
                  {
                    "items": [
                      {
                        "type": "field",
                        "key": "pressure_threshold",
                        "colSpan": 3
                      },
                      {
                        "type": "field",
                        "key": "rate_threshold",
                        "colSpan": 3
                      },
                      {
                        "type": "field",
                        "key": "rolling_points",
                        "colSpan": 3
                      },
                      {
                        "type": "button",
                        "key": "apply",
                        "colSpan": 3,
                        "align": "end"
                      }
                    ]
                  }
                ]
              },
              "actions": [
                {
                  "id": "apply",
                  "label": "Apply",
                  "kind": "submit",
                  "eventId": "apply",
                  "ui": {
                    "color": "primary",
                    "variant": "solid",
                    "size": "sm",
                    "radius": "sm",
                    "fullWidth": true
                  }
                }
              ]
            }
          }
        },
        "events": {
          "fleet_changed": [
            {
              "type": "set_form_values",
              "updates": {
                "fleet_name": "{{form.fleet_name}}",
                "pad_name": null,
                "well_name": "__ALL__"
              }
            }
          ],
          "pad_changed": [
            {
              "type": "set_form_values",
              "updates": {
                "fleet_name": "{{form.fleet_name}}",
                "pad_name": "{{form.pad_name}}",
                "well_name": "__ALL__"
              }
            }
          ],
          "apply": [
            {
              "type": "set_state",
              "updates": {
                "fleet_name": "{{form.fleet_name}}",
                "pad_name": "{{form.pad_name}}",
                "well_name": "{{form.well_name}}",
                "pressure_threshold": "{{form.pressure_threshold}}",
                "rate_threshold": "{{form.rate_threshold}}",
                "rolling_points": "{{form.rolling_points}}",
                "inspect_well": "{{form.well_name}}",
                "inspect_stage": "-1"
              }
            }
          ]
        }
      },
