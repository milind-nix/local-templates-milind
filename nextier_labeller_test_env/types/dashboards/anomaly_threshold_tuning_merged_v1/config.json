              "source": "data:dataset",
              "dimensions": [
                "deltas.timestamp",
                "deltas.delta_pressure",
                "deltas.delta_rate",
                "deltas.pressure_trigger",
                "deltas.rate_trigger",
                "deltas.pressure_threshold",
                "deltas.negative_rate_threshold"
              ]
            },
            "series": [
              {
                "name": "Pressure \u0394",
                "type": "line",
                "xAxisIndex": 0,
                "yAxisIndex": 0,
                "showSymbol": false,
                "sampling": "lttb",
                "encode": {
                  "x": "deltas.timestamp",
                  "y": "deltas.delta_pressure"
                },
                "color": "#D35400"
              },
              {
                "name": "Pressure threshold",
                "type": "line",
                "xAxisIndex": 0,
                "yAxisIndex": 0,
                "showSymbol": false,
                "encode": {
                  "x": "deltas.timestamp",
                  "y": "deltas.pressure_threshold"
                },
                "lineStyle": {
                  "type": "dashed",
                  "width": 1,
                  "color": "#C0392B"
                },
                "tooltip": {
                  "show": false
                }
              },
              {
                "name": "Pressure trigger",
                "type": "scatter",
                "xAxisIndex": 0,
                "yAxisIndex": 0,
                "symbolSize": 7,
                "encode": {
                  "x": "deltas.timestamp",
                  "y": "deltas.pressure_trigger"
                },
                "color": "#C0392B"
              },
              {
                "name": "Rate \u0394",
                "type": "line",
                "xAxisIndex": 1,
                "yAxisIndex": 1,
                "showSymbol": false,
                "sampling": "lttb",
                "encode": {
                  "x": "deltas.timestamp",
                  "y": "deltas.delta_rate"
                },
                "color": "#2878B5"
              },
              {
                "name": "Rate threshold",
                "type": "line",
                "xAxisIndex": 1,
                "yAxisIndex": 1,
                "showSymbol": false,
                "encode": {
                  "x": "deltas.timestamp",
                  "y": "deltas.negative_rate_threshold"
                },
                "lineStyle": {
                  "type": "dashed",
                  "width": 1,
                  "color": "#0B5394"
                },
                "tooltip": {
                  "show": false
                }
              },
              {
                "name": "Rate trigger",
                "type": "scatter",
                "xAxisIndex": 1,
                "yAxisIndex": 1,
                "symbolSize": 7,
                "encode": {
                  "x": "deltas.timestamp",
                  "y": "deltas.rate_trigger"
                },
                "color": "#0B5394"
              }
            ]
          }
        }
      },
      {
        "id": "delta_inspector_form",
        "title": "Delta Inspector",
        "chrome": {
          "showActions": false,
          "hideTitle": false,
          "padding": 8,
          "disableCard": false
        },
        "renderConfig": {
          "library": "Custom",
          "options": {
            "type": "form",
            "config": {
              "schema": {
                "type": "object",
                "required": ["inspect_well", "inspect_stage"],
                "properties": {
                  "inspect_well": {
                    "type": "string",
                    "metadata": {
                      "ui": {
                        "label": "Well",
                        "component": "select",
                        "placeholder": "Select well",
                        "optionsMetric": {
                          "metricKey": "merged_well_options_v1",
                          "params": {
                            "fleet_name": "{{form.fleet_name}}",
                            "pad_name": "{{form.pad_name}}"
                          },
                          "valuePath": "value",
                          "labelPath": "label"
                        },
                        "onChangeEventId": "inspector_well_changed"
                      }
                    }
                  },
                  "inspect_stage": {
                    "type": "string",
                    "metadata": {
                      "ui": {
                        "label": "Stage",
                        "component": "select",
                        "placeholder": "Select stage",
                        "optionsMetric": {
                          "metricKey": "merged_presence_stage_options_v1",
                          "params": {
                            "well_name": "{{form.inspect_well}}"
                          },
                          "valuePath": "value",
                          "labelPath": "label"
                        }
                      }
                    }
                  },
                  "fleet_name": {
                    "type": "string"
                  },
                  "pad_name": {
                    "type": "string"
                  }
                }
              },
              "layout": {
                "cols": 12,
                "gap": 10,
                "rows": [
                  {
                    "items": [
                      {
                        "type": "field",
                        "key": "inspect_well",
                        "colSpan": 5
                      },
                      {
                        "type": "field",
                        "key": "inspect_stage",
                        "colSpan": 5
                      },
                      {
                        "type": "button",
                        "key": "apply_delta_inspector",
                        "colSpan": 2,
                        "align": "end"
                      }
                    ]
                  }
                ]
              },
              "actions": [
                {
                  "id": "apply_delta_inspector",
                  "label": "Apply",
                  "kind": "submit",
                  "eventId": "apply_delta_inspector",
                  "ui": {
                    "color": "primary",
                    "variant": "solid",
                    "size": "sm",
                    "radius": "sm",
                    "fullWidth": true
                  }
                }
              ]
            }
          }
        },
        "events": {
          "inspector_well_changed": [
            {
              "type": "set_form_values",
              "updates": {
                "inspect_well": "{{form.inspect_well}}",
                "inspect_stage": "-1"
              }
            }
          ],
          "apply_delta_inspector": [
            {
              "type": "set_state",
              "updates": {
                "inspect_well": "{{form.inspect_well}}",
                "inspect_stage": "{{form.inspect_stage}}"
              }
            }
          ]
        }
      }
